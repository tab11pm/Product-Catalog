<Window x:Class="ProductCatalogApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProductCatalogApp"
        mc:Ignorable="d"
        Title="Список товаров"
        Height="450"
        Width="900"
        MinHeight="400"
        MinWidth="700">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="3*" />
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <GroupBox Header="Товары" Grid.Column="0" Margin="0,0,10,10">
            <ListBox x:Name="ProductsListBox"
                     DisplayMemberPath="DisplayName"
                     SelectionChanged="ProductsListBox_SelectionChanged"/>
        </GroupBox>

        <GroupBox Header="Информация о товаре" Grid.Column="1" Margin="0,0,0,10">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="170"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,10,10" VerticalAlignment="Center">
                    Название товара:
                </TextBlock>
                <TextBox x:Name="NameTextBox" Grid.Row="0" Grid.Column="1" Margin="0,0,0,10"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,10,10" VerticalAlignment="Center">
                    Производитель:
                </TextBlock>
                <TextBox x:Name="ManufacturerTextBox" Grid.Row="1" Grid.Column="1" Margin="0,0,0,10"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,10,10" VerticalAlignment="Center">
                    Категория:
                </TextBlock>
                <ComboBox x:Name="CategoryComboBox" Grid.Row="2" Grid.Column="1" Margin="0,0,0,10"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,0,10,10" VerticalAlignment="Center">
                    Количество на складе:
                </TextBlock>
                <TextBox x:Name="QuantityTextBox" Grid.Row="3" Grid.Column="1" Margin="0,0,0,10"/>
            </Grid>
        </GroupBox>

        <StackPanel Grid.Row="1" Grid.ColumnSpan="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Left">
            <Button x:Name="AddButton"
                    Width="120"
                    Height="30"
                    Margin="0,0,10,0"
                    Click="AddButton_Click">
                Добавить
            </Button>

            <Button x:Name="SaveButton"
                    Width="170"
                    Height="30"
                    Margin="0,0,10,0"
                    Click="SaveButton_Click">
                Сохранить изменения
            </Button>

            <Button x:Name="DeleteButton"
                    Width="120"
                    Height="30"
                    Click="DeleteButton_Click">
                Удалить
            </Button>
        </StackPanel>
    </Grid>
</Window>
